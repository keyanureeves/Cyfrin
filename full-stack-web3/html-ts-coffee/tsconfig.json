{
  "compilerOptions": {
    "target": "ESNext",              
    "module": "ESNext",              
    "moduleResolution": "Node",      
    "strict": true,                  
    "esModuleInterop": true,         
    "skipLibCheck": true,            
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",              
    "resolveJsonModule": true,       
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true          
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
